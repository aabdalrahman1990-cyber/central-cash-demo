{
  "name": "central-cash-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --workspace @central-cash/web run dev",
    "dev:api": "npm --workspace @central-cash/api run start:dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm --workspace @central-cash/web run build",
    "build:api": "npm --workspace @central-cash/api run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
